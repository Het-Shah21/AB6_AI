# ── Database ──
DATABASE_URL=postgresql+asyncpg://ab6:ab6_pass@localhost:5432/ab6_ai

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── LLM Providers ──
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...

# ── Agent ──
LLM_PRIMARY_PROVIDER=openai
LLM_PRIMARY_MODEL=gpt-4o-mini
LLM_REASONING_MODEL=gpt-4o
LLM_FALLBACK_1_PROVIDER=anthropic
LLM_FALLBACK_1_MODEL=claude-sonnet-4-20250514
LLM_FALLBACK_2_PROVIDER=google_genai
LLM_FALLBACK_2_MODEL=gemini-2.5-flash
LLM_EMBEDDING_MODEL=text-embedding-3-small

# ── Rate Limiting ──
LLM_RATE_LIMIT_RPM=100

# ── Sentry ──
SENTRY_DSN=

# ── Logging ──
LOG_LEVEL=INFO
